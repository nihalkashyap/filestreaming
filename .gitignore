
# ==========================================
# Scala and SBT
# ==========================================
# Ignore target directories generated by sbt compilation
target/
project/target/
project/project/

# Ignore compiled Scala class files
*.class

# Ignore TASTy files generated by Scala 3
*.tasty

# Ignore boot and managed libraries (fetched dynamically by sbt)
lib_managed/
src_managed/
project/boot/

# Ignore sbt update report files
.history
.lib/

# ==========================================
# IntelliJ IDEA
# ==========================================
# Ignore the entire IDE settings directory...
.idea/

# ...EXCEPT for shared files that define the project structure
!.idea/misc.xml
!.idea/modules.xml
!.idea/vcs.xml
!.idea/scala_compiler.xml

# Ignore local user layout and task states
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf/

# Ignore IntelliJ module files (can be regenerated dynamically)
*.iml
*.iws

# ==========================================
# Operating System & Global Files
# ==========================================
.DS_Store
Thumbs.db
*.log
.env
